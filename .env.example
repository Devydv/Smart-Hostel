# Copy this to .env and fill in your values
# Then run: export $(cat .env | xargs) before starting the app

DB_HOST=localhost
DB_USER=hostel
DB_PASSWORD=hostel_pass
DB_NAME=hostel_management
FLASK_SECRET_KEY=change_this_secret
WEB_PORT=5000

# Monitoring
ENABLE_METRICS=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_password
